{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"type": "shell",
			"command": "node esbuild.js && node scripts/build-webview.mjs",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "watch",
			"dependsOn": [
				"npm: watch:esbuild",
				"npm: watch:tsc",
				"npm: watch:webview"
			],
			"presentation": {
				"reveal": "never"
			},
			"group": "build"
		},
		{
			"type": "npm",
			"script": "watch:esbuild",
			"group": "build",
			"problemMatcher": [],
			"isBackground": true,
			"label": "npm: watch:esbuild",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"type": "npm",
			"script": "watch:tsc",
			"group": "build",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"label": "npm: watch:tsc",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"type": "npm",
			"script": "watch:webview",
			"group": "build",
			"problemMatcher": [],
			"isBackground": true,
			"label": "npm: watch:webview",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		}
	]
}
